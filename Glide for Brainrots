})

Window:AddLabel({text = "Made by Zappisme"})

-- Monitor new items
stealableFolder.ChildAdded:Connect(function(child)
    task.wait(0.5)   -- give item time to fully load
    processItem(child)
end)

library:Init()
print("Zaporium GUI + Selective Auto-Steal (respawn-safe) Loaded!")
