-- Find biggest part for teleport (fixes all "No PrimaryPart" issues)
local function getMainPart(model)
    if model.PrimaryPart then return model.PrimaryPart end
    local best, bestSize = nil, 0
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("BasePart") and v.Size.Magnitude > bestSize then
            bestSize = v.Size.Magnitude
            best = v
        end
    end
    return best
end

-- NEW: Collect Cash loop (fires EVERY podium 1-30+ every 1 second)
local function startCollectCash()
    print("🚀 Started Auto Collect Cash (all podiums 1-30 every 1s)")
   
    while running.CollectCash do
        for i = 1, 30 do  -- 30 is safe (covers 1-20 and higher)
            local args = {"CollectCash", i}
            pcall(function()
                game:GetService("ReplicatedStorage")
                    :WaitForChild("Remotes")
                    :WaitForChild("RemoteEvent")
                    :FireServer(unpack(args))
            end)
        end
        task.wait(1)  -- exactly 1 second loop as you asked
    end
   
    print("⛔ Stopped Auto Collect Cash")
end

-- Main farming function for rarities (unchanged)
local function startFarming(rarityName, flag)
    print("🚀 Started Auto " .. rarityName .. " (toggle ON)")
   
    while running[flag] do
        local storage = workspace:FindFirstChild("BrainrotStorage")
        if not storage then
            task.wait(2)
            continue
        end
       
        local targets = {}
        for _, obj in ipairs(storage:GetChildren()) do
            local gui = obj:FindFirstChild("OverheadGui", true)
            local label = gui and gui:FindFirstChild("RarityLabel")
            if label and label.Text == rarityName then
                table.insert(targets, {model = obj, name = obj.Name})
            end
        end
       
        if #targets == 0 then
            task.wait(2.2)
            continue
        end
       
        for _, target in ipairs(targets) do
            if not running[flag] then break end
           
            print("🔄 Farming: " .. target.name .. " (" .. rarityName .. ")")
           
            local targetPart = getMainPart(target.model)
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if targetPart and hrp then
                local offset = CFrame.new(math.random(-4, 4), 8.5, math.random(4, 7))
                hrp.CFrame = targetPart.CFrame * offset
                task.wait(1.1)
            end
           
            local prompt = target.model:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                if fireproximityprompt then
                    fireproximityprompt(prompt)
                else
                    prompt:InputHoldBegin()
                    task.wait((prompt.HoldDuration or 0) + 0.4)
                    prompt:InputHoldEnd()
                end
               
                hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = SAFE_ZONE
                end
               
                task.wait(0.3)
            end
           
            task.wait(2.0)
        end
    end
   
    print("⛔ Stopped Auto " .. rarityName .. " (toggle OFF)")
end

