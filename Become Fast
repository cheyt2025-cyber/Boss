-- NEW: Auto Lucky Block loop (continuous scan + trigger all Lucky Blocks)
spawn(function()
    local player = game.Players.LocalPlayer
    local teleportOffset = Vector3.new(0, 3, 0)
    local waitBetween = 0.4

    while true do
        task.wait(1)  -- Scan every 1s for new blocks (adjust if needed)
        if not autoLuckyEnabled then continue end

        local character = player.Character
        if not character then continue end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        -- Collect all current Lucky Blocks with prompts
        local luckyBlocks = {}
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "Lucky Block" and (obj:IsA("BasePart") or obj:IsA("Model")) then
                local prompt = obj:FindFirstChild("ProximityPrompt", true)
                or (obj:IsA("BasePart") and obj:FindFirstChildOfClass("ProximityPrompt"))
                if prompt and prompt:IsA("ProximityPrompt") then
                    table.insert(luckyBlocks, {obj = obj, prompt = prompt})
                end
            end
        end

        -- Process each one (exact method from your script)
        for _, data in ipairs(luckyBlocks) do
            pcall(function()
                -- Smooth teleport (anti-vibration)
                hrp.Velocity = Vector3.new(0, 0, 0)
                hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

                hrp.CFrame = data.obj:GetPivot() + teleportOffset

                task.wait(0.15)

                data.prompt:InputHoldBegin()
                task.wait(data.prompt.HoldDuration + 0.1)
                data.prompt:InputHoldEnd()

                print("Triggered Lucky Block @ " .. tostring(data.obj:GetPivot().Position))
            end)

            task.wait(waitBetween)
        end
    end
end)

