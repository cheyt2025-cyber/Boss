local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Zap-Zaporium/Zap-is-Me/refs/heads/main/Zaporium.lua"))()

local Window = library:CreateWindow("Become Fast")
local Main = Window:AddFolder("Main Features")

-- ===== COLLECT TELEPORTS =====
local W1 = workspace:WaitForChild("Obbys"):WaitForChild("W1")

local collectParts = {}
local winNames = {"Win1", "Win3", "Win10", "Win15"}  -- No WinVIP

for _, winName in ipairs(winNames) do
    local success, part = pcall(function()
        return W1:WaitForChild(winName):WaitForChild("Finish"):WaitForChild("Collect")
    end)
    if success and part then
        collectParts[winName] = part
    else
        warn("Collect not found for " .. winName)
    end
end

local enabledCollects = {}
for _, winName in ipairs(winNames) do
    enabledCollects[winName] = false
end

-- Teleport loop (smooth, anti-vibration)
spawn(function()
    local player = game.Players.LocalPlayer
    while true do
        wait(0.18)
        local character = player.Character
        if not character then continue end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local activeParts = {}
        for winName, isEnabled in pairs(enabledCollects) do
            if isEnabled and collectParts[winName] then
                table.insert(activeParts, collectParts[winName])
            end
        end
        if #activeParts == 0 then continue end

        local cycleIndex = math.floor(tick() * 5) % #activeParts + 1
        local destination = activeParts[cycleIndex]

        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
        hrp.AssemblyAngularVelocity = Vector3.new(0,0,0)

        local offset = Vector3.new(math.random(-4,4)/10, 3, math.random(-4,4)/10)
        hrp.CFrame = destination.CFrame + offset
    end
end)

