-- ==================== OLD AUTO FARM TOGGLES ====================
local autoSecret = false
local autoCelestial = false
local autoDivine = false

local function updateAutoFarm()
	local activeRarities = {}
	if autoSecret then table.insert(activeRarities, "Secret") end
	if autoCelestial then table.insert(activeRarities, "Celestial") end
	if autoDivine then table.insert(activeRarities, "Divine") end

	if #activeRarities > 0 then
		startAutoFarm(activeRarities)
	else
		stopAutoFarm()
	end
end

