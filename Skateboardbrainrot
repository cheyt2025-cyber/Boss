-- ==================== AUTO FARM FUNCTIONS ====================
local function triggerBrainrot(brainrotModel)
	if not brainrotModel or not brainrotModel:FindFirstChild("HumanoidRootPart") then return end

	local hitbox = brainrotModel:FindFirstChild("Hitbox")
	local prompt = hitbox and hitbox:FindFirstChild("BrainrotPrompt")

	rootPart.CFrame = brainrotModel.HumanoidRootPart.CFrame + Vector3.new(0, 5, 0)
	wait(0.6)

	if prompt and prompt:IsA("ProximityPrompt") then
		fireproximityprompt(prompt)
	end

	wait(1.2)
	rootPart.CFrame = SAFE_ZONE_CFRAME
end

local function startAutoFarm(selectedRarities)
	if running then return end
	running = true

	print("Auto Farm Started for:", table.concat(selectedRarities, ", "))

	currentConnection = brainrotsFolder.DescendantAdded:Connect(function(descendant)
		if not running then return end
		if descendant:IsA("UIStroke") and descendant.Name == "UIStroke" and 
		   descendant.Parent and descendant.Parent.Name == "BrainrotName" then

			local displayName = descendant.Parent.Text
			if highTierData[displayName] and table.find(selectedRarities, highTierData[displayName]) then
				local brainrotModel = descendant:FindFirstAncestorWhichIsA("Model")
				if brainrotModel then
					print("Auto-farming:", displayName, "(", highTierData[displayName], ")")
					triggerBrainrot(brainrotModel)
					wait(2)
				end
			end
		end
	end)

	-- Initial scan
	for _, descendant in ipairs(brainrotsFolder:GetDescendants()) do
		if not running then break end
		-- (same logic as above if you want initial scan)
	end
end

local function stopAutoFarm()
	running = false
	if currentConnection then
		currentConnection:Disconnect()
		currentConnection = nil
	end
	print("Auto Farm Stopped")
end

-- ==================== BOOST FUNCTIONS ====================
local function startBuyBoost()
	if boostCoroutine then return end
	boostCoroutine = coroutine.create(function()
		local buyBoostRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("BuyBoost")
		while buyBoostEnabled do
			buyBoostRemote:InvokeServer()
			task.wait(0.5)
		end
	end)
	coroutine.resume(boostCoroutine)
end

local function stopBuyBoost()
	buyBoostEnabled = false
	boostCoroutine = nil
end

local function startBuySpeed()
	if speedCoroutine then return end
	speedCoroutine = coroutine.create(function()
		local buySpeedRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("BuySpeed")
		local args = {5}
		while buySpeedEnabled do
			buySpeedRemote:InvokeServer(unpack(args))
			task.wait(0.5)
		end
	end)
	coroutine.resume(speedCoroutine)
end

local function stopBuySpeed()
	buySpeedEnabled = false
	speedCoroutine = nil
end

