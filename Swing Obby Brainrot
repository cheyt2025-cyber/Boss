local hasDetectedPlot = false
local myPlotNumber

local function fireTouch(toucher, target)
    if not toucher or not target then return end
    pcall(function()
        firetouchinterest(toucher, target, 0)
        task.wait(0.03)
        firetouchinterest(toucher, target, 1)
    end)
end

local function touchAllPods(plotNumber)
    local plot = Workspace.Plots:FindFirstChild("Plot" .. plotNumber)
    if not plot then return end
    local podsFolder = plot:FindFirstChild("Pods")
    if not podsFolder then return end
    local character = player.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    for _, pod in ipairs(podsFolder:GetChildren()) do
        local touchPart = pod:FindFirstChild("TouchPart")
        if touchPart then
            fireTouch(rootPart, touchPart)
            for _, child in ipairs(touchPart:GetChildren()) do
                if child.Name == "Upgrade" or child:IsA("BasePart") or child.Name:find("Touch") or child.Name:find("Surface") then
                    fireTouch(rootPart, child)
                end
            end
        end
        task.wait(0.08)
    end
end

local function detectMyPlot()
    if hasDetectedPlot then return player:GetAttribute("MyPlotNumber") or myPlotNumber end
    local character = player.Character or player.CharacterAdded:Wait()
    local root = character:WaitForChild("HumanoidRootPart")
    local plotsFolder = Workspace:WaitForChild("Plots")
    local closestPlot, closestDist = nil, math.huge
    for _, plot in ipairs(plotsFolder:GetChildren()) do
        local spawnPart = plot:FindFirstChild("SpawnPart")
        if spawnPart and spawnPart:IsA("BasePart") then
            local dist = (root.Position - spawnPart.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                closestPlot = plot
            end
        end
    end
    if closestPlot then
        local num = tonumber(closestPlot.Name:match("%d+"))
        if num then
            myPlotNumber = num
            player:SetAttribute("MyPlotNumber", num)
            hasDetectedPlot = true
            print("✅ Detected your plot → #" .. num)
            return num
        end
    end
    return nil
end

task.spawn(function() task.wait(1.5) detectMyPlot() end)
player.CharacterAdded:Connect(function() task.wait(1.2) detectMyPlot() end)

local function collectCashLoop()
    while collectCashRunning and task.wait(1) do
        if not myPlotNumber then detectMyPlot() end
        if myPlotNumber then touchAllPods(myPlotNumber) end
    end
end

