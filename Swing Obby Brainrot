local function parseEarnings(text)
    if not text then return 0 end
    text = tostring(text):upper():gsub(",", ""):gsub(" ", "")
    local num = tonumber(text:match("%d+%.?%d*")) or 0
    if text:find("K") then num *= 1000
    elseif text:find("M") then num *= 1000000
    elseif text:find("B") then num *= 1000000000 end
    return num
end

local function getModelData(model)
    if not model:IsA("Model") then return nil end
    local levelBoard = model:FindFirstChild("LevelBoard", true)
    if not levelBoard then return nil end
    local frame = levelBoard:FindFirstChild("Frame", true)
    if not frame then return nil end
    local earningsObj = frame:FindFirstChild("CurrencyFrame") and frame.CurrencyFrame:FindFirstChild("Earnings")
    if not earningsObj then return nil end
    local text = earningsObj.Text or tostring(earningsObj.Value or "0")
    local num = parseEarnings(text)
    return { model = model, earningsNum = num, earningsText = text }
end

local function findHighestEarningModel()
    local best = nil
    local bestValue = -math.huge
    for _, child in ipairs(folder:GetChildren()) do
        if child == lastCollected and tick() - lastCollectedTime < 4 then
            continue
        end
        local data = getModelData(child)
        if data and data.earningsNum > bestValue then
            bestValue = data.earningsNum
            best = data
        end
    end
    return best
end

local function autoHighestLoop()
    -- ONE-TIME zone teleport (only when first enabled)
    if not hasZoneTeleported then
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local hrp = char.HumanoidRootPart
            local zoneCFrame = zone10:IsA("Model") and zone10:GetPivot() or (zone10:IsA("BasePart") and zone10.CFrame)
            if zoneCFrame then
                hrp.CFrame = zoneCFrame * CFrame.new(0, 5, 0)
                print("🚀 Started at Zones[10]")
                task.wait(2.2)
                hasZoneTeleported = true
            end
        end
    end

    while autoHighestRunning do
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then
            task.wait(1)
            continue
        end
        local hrp = char.HumanoidRootPart

        local target = findHighestEarningModel()
        if not target then
            print("No targets right now...")
            task.wait(3)
            continue
        end

        print(string.format("→ FAST TARGET: %s | %s", target.model.Name, target.earningsText))

        -- Direct teleport
        local modelCFrame = target.model:GetPivot()
        local offset = CFrame.new(0, 4, 8)
        hrp.CFrame = modelCFrame * offset

        task.wait(1.7)

        -- Find prompt
        local prompt = nil
        for _, desc in ipairs(target.model:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                prompt = desc
                break
            end
        end
        if not prompt then
            prompt = Workspace:FindFirstChildWhichIsA("ProximityPrompt", true)
        end

        local holdTime = prompt and (prompt.HoldDuration + 0.25) or 1.35

        -- Hold E
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(holdTime)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

        print("   Collected!")

        lastCollected = target.model
        lastCollectedTime = tick()

        task.wait(3.5)
    end
end

