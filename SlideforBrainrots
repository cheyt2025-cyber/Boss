local LuckyFolder = Window:AddFolder("Farm LuckyBlocks")

local autoLuckyRunning = false

local targetNames = {"SecretLuckyBlock", "GodlyLuckyBlock", "LegendaryLuckyBlock", "Secret", "Godly"}
local remote = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("EventManagerClient"):WaitForChild("ServerEvent")

local FLOAT_HEIGHT = 30
local SAFE_DISTANCE = 35
local SPAM_DURATION = 5

local function getRarity(obj)
    local mesh = obj:FindFirstChild("Mesh")
    if not mesh then return nil end
    local bui = mesh:FindFirstChild("BUI_Brainrot")
    if not bui then return nil end
    local main = bui:FindFirstChild("Main")
    if not main then return nil end
    local txt = main:FindFirstChild("RarityTxt")
    return (txt and txt:IsA("TextLabel")) and txt.Text or nil
end

local function getSafeLandingCFrame(obj)
    local blockPos = obj:GetPivot().Position
    local direction = Vector3.new(math.random(-5,5), 50, SAFE_DISTANCE + math.random(-8,8))
    local startPos = blockPos + direction
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {player.Character}

    local rayResult = workspace:Raycast(startPos, Vector3.new(0, -100, 0), raycastParams)
    if rayResult then
        local groundY = rayResult.Position.Y + 6
        return CFrame.new(blockPos.X + direction.X, groundY, blockPos.Z + direction.Z)
    else
        return CFrame.new(blockPos.X + direction.X, blockPos.Y + 10, blockPos.Z + direction.Z)
    end
end

