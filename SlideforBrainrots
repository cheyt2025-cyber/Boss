-- Brainrots helpers (unchanged from previous)
local function cleanName(raw)
    if typeof(raw) ~= "string" then return "" end
    local cleaned = raw:match("^%d+%s*_+%s*(.+)$") or raw
    return cleaned:match("^%s*(.-)%s*$") or cleaned
end

local function getBrainrotInfo(model)
    if not model:IsA("Model") then return nil end

    local nameGui = model:FindFirstChild("Mesh", true)
    and model.Mesh:FindFirstChild("BUI_Brainrot", true)
    and model.Mesh.BUI_Brainrot:FindFirstChild("Main", true)
    and model.Mesh.BUI_Brainrot.Main

    if not nameGui then return nil end

    local nameTxt = nameGui:FindFirstChild("NameTxt")
    if not (nameTxt and nameTxt:IsA("TextLabel")) then return nil end

    local clean = cleanName(nameTxt.Text)

    local rarity
    if secretLookup[clean] then rarity = "Secret"
    elseif godlyLookup[clean] then rarity = "Godly" end

    if not rarity then return nil end

    local prompt = model:FindFirstChild("Mesh", true)
    and model.Mesh:FindFirstChild("ProximityPrompt", true)

    return {
        Model     = model,
        Rarity    = rarity,
        CleanName = clean,
        Prompt    = prompt and prompt:IsA("ProximityPrompt") and prompt or nil,
    }
end

local function teleportTo(pos)
    local char = player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = CFrame.new(pos) * CFrame.new(0, 4, 0)
    print("Teleported to: " .. tostring(pos))
    return true
end

local function spamClaim()
    local start = tick()
    local count = 0
    while tick() - start < 6.1 do
        pcall(function() event:FireServer("ClaimBrainrots") end)
        count = count + 1
        task.wait(0.15)
    end
    print("Claim spam done (" .. count .. " fires)")
end

local function forceTeleportToArea()
    local startPos = Vector3.new(567.69, -3258.27, 10453.23)
    local attempts = 0
    while attempts < 6 do
        if teleportTo(startPos) then
            task.wait(2.2)
            return
        end
        attempts = attempts + 1
        task.wait(1)
    end
end

local function farmLoop(rarity)
    while (rarity == "Godly" and autoGodlyRunning) or (rarity == "Secret" and autoSecretRunning) do
        forceTeleportToArea()
        local found = false
        for _, child in ipairs(brainrotsFolder:GetChildren()) do
            local info = getBrainrotInfo(child)
            if info and info.Prompt and info.Rarity == rarity then
                found = true
                print("★ " .. info.Rarity .. " → " .. info.CleanName)
                local rootPart = info.Model:FindFirstChild("Mesh") or info.Model.PrimaryPart
                local targetPos = rootPart and rootPart.Position or info.Model:GetPivot().Position
                teleportTo(targetPos)
                task.wait(0.6)
                if info.Prompt.Enabled then
                    fireproximityprompt(info.Prompt)
                end
                spamClaim()
                task.wait(1.5)
                break
            end
        end
        if not found then
            task.wait(2.2)
        end
        RunService.Heartbeat:Wait()
    end
end

