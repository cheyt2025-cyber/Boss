local function luckyFarmLoop()
    while autoLuckyRunning do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then
            task.wait(1)
            continue
        end

        local targets = {}
        for _, obj in ipairs(brainrotsFolder:GetChildren()) do
            local name = obj.Name
            if table.find(targetNames, name) then
                local rarity = getRarity(obj) or name
                if rarity:match("Secret") or rarity:match("Godly") or rarity:match("Legendary") then
                    table.insert(targets, {obj = obj, name = name, rarity = rarity})
                end
            end
        end

        if #targets == 0 then
            task.wait(0.5)
            continue
        end

        -- Priority sort: Secret > Godly > Legendary
        table.sort(targets, function(a, b)
            local prioA = (a.rarity:find("Secret") and 3) or (a.rarity:find("Godly") and 2) or 1
            local prioB = (b.rarity:find("Secret") and 3) or (b.rarity:find("Godly") and 2) or 1
            return prioA > prioB or (prioA == prioB and #a.name > #b.name)
        end)

        local best = targets[1]
        local obj = best.obj
        print("🎯 [SAFE FARM] Targeting: " .. best.rarity .. " (" .. obj.Name .. ")")

        local offsets = {
            CFrame.new(0, 3, -6),
            CFrame.new(0, 5, -4),
            CFrame.new(0, 4, -8),
            CFrame.new(2, 3, -5),
            CFrame.new(-2, 3, -5)
        }

        local promptTriggered = false
        hrp.Anchored = false

        for i, offset in ipairs(offsets) do
            hrp.CFrame = obj:GetPivot() * offset
            print("Teleport #" .. i)
            task.wait(1.6)

            local mainFolder = obj:FindFirstChild("Main")
            local targetPrompt = mainFolder and mainFolder:FindFirstChild("ProximityPrompt")

            if targetPrompt and targetPrompt.Enabled then
                print("✅ PROMPT TRIGGERED!")
                pcall(function()
                    targetPrompt:InputHoldBegin()
                    task.wait(targetPrompt.HoldDuration + 0.3)
                    targetPrompt:InputHoldEnd()
                end)
                promptTriggered = true
                break
            end
        end

        -- Float up + anchor
        local upTarget = hrp.CFrame + Vector3.new(0, FLOAT_HEIGHT, 0)
        local floatUp = TweenService:Create(hrp, TweenInfo.new(0.9, Enum.EasingStyle.Quart), {CFrame = upTarget})
        floatUp:Play()
        floatUp.Completed:Wait()

        hrp.Anchored = true
        print("🛫 ANCHORED @ +" .. FLOAT_HEIGHT .. " — INVINCIBLE!")

        -- Spam
        local start = tick()
        while tick() - start < SPAM_DURATION do
            pcall(function()
                remote:FireServer("ClaimBrainrots")
            end)
            task.wait(0.08)
        end
        print("💰 5s SPAM DONE!")

        -- Safe escape
        local safeLandCFrame = getSafeLandingCFrame(obj)
        print("📍 Safe land @ " .. tostring(safeLandCFrame.Position))

        local farHigh = safeLandCFrame + Vector3.new(0, 15, 0)
        local escapeTween = TweenService:Create(hrp, TweenInfo.new(1.2, Enum.EasingStyle.Quart), {CFrame = farHigh})
        escapeTween:Play()
        escapeTween.Completed:Wait()

        local landTween = TweenService:Create(hrp, TweenInfo.new(1.5, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out), {CFrame = safeLandCFrame})
        landTween:Play()
        landTween.Completed:Wait()

        hrp.Anchored = false
        print("✅ [CYCLE COMPLETE] Landed safe — Guards BTFO!")

        task.wait(0.6)
    end
    print("[LuckyBlocks Auto Farm] Stopped")
end

