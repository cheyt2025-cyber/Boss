-- ────────────────────────────────────────────────
-- Auto-farm logic (same as working version)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local SAFEZONE_CFRAME = CFrame.new(28.36, 133.75, -4.35)
local PRIORITY = {"Admin", "OG", "Secret", "Mythical"}

local mobsFolder = workspace:WaitForChild("Mobs", 10)
if not mobsFolder then warn("Mobs folder missing") return end

local function anyFarmActive()
    for _, v in pairs(autoFarmToggles) do if v then return true end end
    return false
end

local function getRarity(mob)
    local root    = mob:FindFirstChild("RootPart")     if not root    then return nil end
    local attach  = root:FindFirstChild("OverheadAttach") if not attach  then return nil end
    local overhead = attach:FindFirstChild("AnimalOverhead") if not overhead then return nil end
    local rarityObj = overhead:FindFirstChild("Rarity") if not rarityObj then return nil end

    local txt = rarityObj.Text or rarityObj.Value or ""
    return (txt:match("^%s*(.-)%s*$") or txt):lower()
end

local function farmOnCharacter(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then warn("No HRP") return end

    task.wait(0.8)  -- settle after spawn
    print("Character ready – auto farm running")

    while true do
        if not anyFarmActive() then task.wait(1.2) continue end

        local bestMob, bestPriority = nil, #PRIORITY + 1

        for _, mob in ipairs(mobsFolder:GetChildren()) do
            local r = getRarity(mob)
            if not r then continue end

            for i, target in ipairs(PRIORITY) do
                if r == target:lower() and autoFarmToggles[target] and i < bestPriority then
                    bestPriority = i
                    bestMob = mob
                    break
                end
            end
        end

        if not bestMob then task.wait(1.2) continue end

        print("Farm → " .. bestMob.Name)

        local root = bestMob:FindFirstChild("RootPart")
        if not root then task.wait(0.4) continue end

        char:PivotTo(root.CFrame * CFrame.new(0, 3.2, -2.8) * CFrame.Angles(0, math.rad(180), 0))
        task.wait(0.5)

        local prompt = root:FindFirstChildWhichIsA("ProximityPrompt", true)

        local success = false

        if prompt and prompt.Enabled then
            if prompt.MaxActivationDistance < 6 or prompt.RequiresLineOfSight then
                char:PivotTo(root.CFrame * CFrame.new(0, 2.4, -1.6) * CFrame.Angles(0, math.rad(180), 0))
                task.wait(0.25)
            end

            prompt:InputHoldBegin()
            local hold = prompt.HoldDuration > 0 and prompt.HoldDuration + 0.25 or 0.18
            task.wait(hold)
            prompt:InputHoldEnd()

            task.wait(0.8)

            if not bestMob.Parent then success = true end
        end

        task.wait(0.15)
        char:PivotTo(SAFEZONE_CFRAME)
        print("Safe")

        task.wait(0.6 + (success and 0.5 or 0))
    end
end

-- Start / respawn handling
if player.Character then farmOnCharacter(player.Character) end
player.CharacterAdded:Connect(farmOnCharacter)
