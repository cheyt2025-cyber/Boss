-- Zaporium GUI + Auto Farm + Auto Upgrades + Auto Rebirth

local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Zap-Zaporium/Zap-is-Me/refs/heads/main/Zaporium.lua"))()

-- Services
local Players           = game:GetService("Players")
local TweenService      = game:GetService("TweenService")
local Workspace         = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService        = game:GetService("RunService")

local player = Players.LocalPlayer

-- ────────────────────────────────────────────────
-- Farm Config (unchanged)
-- ────────────────────────────────────────────────
local SAFE_ZONE_CFRAME = CFrame.new(-104.84, 3.51, 718.21)

local DELAY_AFTER_ADDED     = 0.22
local REVEAL_WAIT           = 0.38
local DELAY_AFTER_UNDER     = 0.10
local ANCHOR_DURATION       = 0.50
local POST_UNANCHOR_WAIT    = 0.12
local FIRE_LOOP_COUNT       = 10
local FIRE_DELAY_PER_SHOT   = 0.016
local POST_FIRE_WAIT        = 0.85
local UNDER_Y               = -19

local DOWN_INFO  = TweenInfo.new(0.6, Enum.EasingStyle.Linear)
local HORIZ_INFO = TweenInfo.new(0.7, Enum.EasingStyle.Linear)
local UP_INFO    = TweenInfo.new(0.9, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

-- Toggle states
local autoSecretEnabled   = false
local autoDivineEnabled   = false
local upgradeJumpEnabled  = false
local upgradeSpeedEnabled = false
local autoRebirthEnabled  = false

-- ────────────────────────────────────────────────
-- Shared upgrade/rebirth loop
-- ────────────────────────────────────────────────
local loopConnection

local function startLoop()
    if loopConnection then loopConnection:Disconnect() end

    loopConnection = RunService.Heartbeat:Connect(function()
        local anyActive = upgradeJumpEnabled or upgradeSpeedEnabled or autoRebirthEnabled

        if not anyActive then
            loopConnection:Disconnect()
            loopConnection = nil
            return
        end

        if upgradeJumpEnabled then
            local args = {"upgrade", "JumpHeight", 1}
            ReplicatedStorage:WaitForChild("Signal"):WaitForChild("Upgrade"):FireServer(unpack(args))
        end

        if upgradeSpeedEnabled then
            local args = {"upgrade", "WalkSpeed", 1}
            ReplicatedStorage:WaitForChild("Signal"):WaitForChild("Upgrade"):FireServer(unpack(args))
        end

        if autoRebirthEnabled then
            ReplicatedStorage:WaitForChild("Signal"):WaitForChild("Rebirth_Server"):FireServer()
        end

        task.wait(0.5)  -- upgrades every 0.5s
        -- rebirth fires every ~1s because of the task.wait(0.5) × 2
    end)
end

-- ────────────────────────────────────────────────
-- Farm logic (shortened – same as before)
-- ────────────────────────────────────────────────
local divineNames = {"Torrtuginni Dragonfrutini","Agarrini La Pallini","Tralaledon","Chicleteirina Bicicleteirina","Tirilikalika Tirilikalako","69","Swag Soda","Pepe","Lionelo Cactuseli"}
local secretNames = {"67","Triplito Tralaleritos","Karkerkar Kurkur","Trollface","Illuminati","Nyan Cat","Skibidi Toilet","Ben","Happy Banana Cat"}

local function isDivine(name) for _,v in divineNames do if name==v then return true end end return false end
local function isSecret(name) for _,v in secretNames do if name==v then return true end end return false end

local function getHRP()
    local char = player.Character
    if char then return char:FindFirstChild("HumanoidRootPart") end
    return nil
end

local function tweenUnderToSafe()
    local hrp = getHRP()
    if not hrp then return end

    hrp.Anchored = false
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    local start = hrp.Position
    local safe  = SAFE_ZONE_CFRAME.Position

    -- down
    local t1 = TweenService:Create(hrp, DOWN_INFO, {CFrame = CFrame.new(start.X, UNDER_Y, start.Z)})
    t1:Play() t1.Completed:Wait()

    -- horizontal
    local t2 = TweenService:Create(hrp, HORIZ_INFO, {CFrame = CFrame.new(safe.X, UNDER_Y, safe.Z)})
    t2:Play() t2.Completed:Wait()

    -- up
    local t3 = TweenService:Create(hrp, UP_INFO, {CFrame = SAFE_ZONE_CFRAME})
    t3:Play() t3.Completed:Wait()
end

local function claimDrop(model)
    local hrp = getHRP()
    if not hrp or not model.Parent then return end

    local pivot = model:GetPivot()

    hrp.CFrame = CFrame.lookAt(pivot.Position + Vector3.new(0,5.5,0), pivot.Position + Vector3.new(0,2,7))
    task.wait(REVEAL_WAIT)

    local upos = pivot.Position - Vector3.new(0,4.6,0)
    hrp.CFrame = CFrame.lookAt(upos, upos + pivot.LookVector * 6)
    hrp.Anchored = true
    task.wait(ANCHOR_DURATION)

    hrp.Anchored = false
    task.wait(POST_UNANCHOR_WAIT)

    for _, p in model:GetDescendants() do
        if p:IsA("ProximityPrompt") then
            p.Enabled = true
            for _ = 1, FIRE_LOOP_COUNT do
                fireproximityprompt(p)
                task.wait(FIRE_DELAY_PER_SHOT)
            end
        end
    end

    task.wait(POST_FIRE_WAIT)
    tweenUnderToSafe()
end

local queue = {}
local isBusy = false

local function processNext()
    if isBusy or #queue == 0 then return end
    isBusy = true
    local m = table.remove(queue, 1)
    task.spawn(function()
        claimDrop(m)
        isBusy = false
        processNext()
    end)
end

local function onDrop(child)
    task.wait(DELAY_AFTER_ADDED)
    if child:IsA("Model") and child.Name and child.Parent then
        local n = child.Name
        if (isDivine(n) and autoDivineEnabled) or (isSecret(n) and autoSecretEnabled) then
            table.insert(queue, child)
            processNext()
        end
    end
end

task.spawn(function()
    local f = Workspace:WaitForChild("DropModelFolder", 15)
    if f then
        for _,c in f:GetChildren() do task.spawn(onDrop, c) end
        f.ChildAdded:Connect(onDrop)
    end
end)

player.CharacterAdded:Connect(function()
    task.wait(1.3)
    local h = getHRP()
    if h then h.CFrame = SAFE_ZONE_CFRAME end
end)

