
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Zap-Zaporium/Zap-is-Me/refs/heads/main/Zaporium.lua"))()

local Window = library:CreateWindow("Cut Grass Brainrot")

-- Services
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local hrp = nil

local START_POS = CFrame.new(880.77, 37.81, -6.64)
local HOME_POS  = CFrame.new(-875.15, 37.79, 8.30)

local TWEEN_DURATION = 1.2
local DELAY_AFTER_COLLECT = 1.0

local tweenInfo = TweenInfo.new(TWEEN_DURATION, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

-- Get HRP safely
local function getHRP()
    if hrp and hrp.Parent then return hrp end
    local char = player.Character or player.CharacterAdded:Wait()
    hrp = char:WaitForChild("HumanoidRootPart", 10)
    return hrp
end

player.CharacterAdded:Connect(function() task.wait(0.6); getHRP() end)
getHRP()

local function tweenTo(cf)
    if not hrp or not hrp.Parent then return end
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = cf})
    tween:Play()
    tween.Completed:Wait()
end

-- Collect function
local function tryCollectOne(obj)
    local prompt = obj:FindFirstChild("Take", true) or obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt and prompt:IsA("ProximityPrompt") and fireproximityprompt then
        fireproximityprompt(prompt, 0)
        task.wait(0.4)
        return
    end

    local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    if part then
        tweenTo(part.CFrame * CFrame.new(0, 3.5, 0))
        task.wait(0.8)
    end
end

local function processObject(obj, name)
    if not obj:IsA("Model") or not hrp then return end
    local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
    if not part then return end

    print("[" .. name .. "] → " .. obj.Name)
    tweenTo(part.CFrame * CFrame.new(0, 4, 0))

    tryCollectOne(obj)

    print("[" .. name .. "] Home")
    tweenTo(HOME_POS)
    task.wait(DELAY_AFTER_COLLECT)
end

-- Folder functions
local function getCelestialFolder()
    local zones = workspace:WaitForChild("Zones", 15)
    local lava8 = zones:WaitForChild("Lava_8", 10)
    return lava8:WaitForChild("SpawnZone", 10)
end

local function getSecretFolder()
    local zones = workspace:WaitForChild("Zones", 15)
    local lava7 = zones:WaitForChild("Lava_7", 10)
    return lava7:WaitForChild("SpawnZone", 10)
end

local function startAuto(folderName, getFolderFunc, toggleRef)
    local folder = getFolderFunc()
    if not folder then
        print(folderName .. " folder still not found after waiting.")
        return
    end

    print(folderName .. " folder found! Starting...")

    for _, obj in ipairs(folder:GetChildren()) do
        if not toggleRef.value then break end
        processObject(obj, folderName)
    end

    folder.ChildAdded:Connect(function(newObj)
        if not toggleRef.value then return end
        task.wait(0.5)
        processObject(newObj, folderName)
    end)
end

-- ==================== TOGGLES & BUTTONS ====================

local celestialToggle = {value = false}
Window:AddToggle({
    text = "Auto Celestial",
    state = false,
    callback = function(enabled)
        celestialToggle.value = enabled
        if enabled then
            print("Auto Celestial → ON")
            if not getHRP() then return end
            tweenTo(START_POS)
            startAuto("Celestial", getCelestialFolder, celestialToggle)
        else
            print("Auto Celestial → OFF")
        end
    end
})

local secretToggle = {value = false}
Window:AddToggle({
    text = "Auto Secret",
    state = false,
    callback = function(enabled)
        secretToggle.value = enabled
        if enabled then
            print("Auto Secret → ON")
            if not getHRP() then return end
            tweenTo(START_POS)
            startAuto("Secret", getSecretFolder, secretToggle)
        else
            print("Auto Secret → OFF")
        end
    end
})

