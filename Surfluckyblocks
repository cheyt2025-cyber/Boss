-- ==================== AUTO STEAL (FIXED) ====================
local friendsFolder = workspace:WaitForChild("Live"):WaitForChild("Friends")
local player = game.Players.LocalPlayer
local safeZone = CFrame.new(-106.19, 4.86, 252.90)

local enabledRarities = {}
local processing = false
local floatConnection = nil
local childAddedConn = nil
local stealThread = nil  -- For initial scan control

local function startFloating(rootPart)
    if floatConnection then floatConnection:Disconnect() end
    floatConnection = game:GetService("RunService").Heartbeat:Connect(function()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and rootPart and rootPart.Parent then
            local targetPos = rootPart.Position + Vector3.new(0, 15, 0)
            hrp.CFrame = CFrame.new(targetPos) * CFrame.Angles(0, hrp.CFrame.Rotation.Y, 0)
        end
    end)
end

local function stopFloating()
    if floatConnection then
        floatConnection:Disconnect()
        floatConnection = nil
    end
end

local function stealRare(friend)
    if processing then return end
    processing = true

    local rarityLabel = friend:FindFirstChild("FriendBillboard", true)
                     and friend.FriendBillboard:FindFirstChild("Frame", true)
                     and friend.FriendBillboard.Frame:FindFirstChild("Rarity")

    if not rarityLabel or not enabledRarities[rarityLabel.Text] then
        processing = false
        return
    end

    local rarity = rarityLabel.Text
    print(rarity)

    local root = friend:FindFirstChild("RootPart") or friend:FindFirstChild("HumanoidRootPart")
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")

    if root and hrp then
        startFloating(root)
        task.wait(0.8)

        local prompt = friend:FindFirstChild("StealPrompt", true)
        if prompt and prompt:IsA("ProximityPrompt") then
            fireproximityprompt(prompt)
        end

        task.wait(1.5)
    end

    stopFloating()

    if hrp then
        hrp.CFrame = safeZone
    end

    processing = false
end

local function startMonitoring()
    -- Stop any previous monitoring
    if childAddedConn then childAddedConn:Disconnect() end
    if stealThread then task.cancel(stealThread) end

    -- New ChildAdded
    childAddedConn = friendsFolder.ChildAdded:Connect(function(friend)
        task.wait(0.4)
        stealRare(friend)
    end)

    -- Initial scan in controlled thread
    stealThread = task.spawn(function()
        for _, friend in ipairs(friendsFolder:GetChildren()) do
            if not next(enabledRarities) then break end  -- safety
            task.wait(0.4)
            stealRare(friend)
        end
    end)
end

local function stopMonitoring()
    if childAddedConn then
        childAddedConn:Disconnect()
        childAddedConn = nil
    end
    if stealThread then
        task.cancel(stealThread)
        stealThread = nil
    end
    stopFloating()
    processing = false
end

