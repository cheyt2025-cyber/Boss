-- ==================== COLLECT CASH ====================
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local localPlayer = Players.LocalPlayer
local plotsFolder = Workspace:WaitForChild("Plots")

local collectThread = nil

local function findMyBasePos()
    for _, basePos in ipairs(plotsFolder:GetChildren()) do
        local ownerSign = basePos:FindFirstChild("OwnerSign")
        if ownerSign then
            local main = ownerSign:FindFirstChild("Main")
            if main then
                local surfaceGui = main:FindFirstChild("SurfaceGui")
                if surfaceGui then
                    local textLabel = surfaceGui:FindFirstChild("TextLabel")
                    if textLabel and textLabel.Text == localPlayer.Name then
                        return basePos
                    end
                end
            end
        end
    end
    return nil
end

local function autoCollectMyPads()
    local myPlot = findMyBasePos()
    if not myPlot then return end

    local collectPadsFolder = myPlot:FindFirstChild("CollectPads")
    if not collectPadsFolder then return end

    local character = localPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChildWhichIsA("BasePart")
    if not rootPart then return end

    for _, pad in ipairs(collectPadsFolder:GetChildren()) do
        local topPart = pad:FindFirstChild("Top")
        if topPart then
            local touchInterest = topPart:FindFirstChild("TouchInterest") or topPart:FindFirstChildWhichIsA("TouchInterest")
            if touchInterest then
                firetouchinterest(rootPart, topPart, 0)
                task.wait(0.05)
                firetouchinterest(rootPart, topPart, 1)
            end
        end
    end
end

Window:AddToggle({
    text = "Collect Cash",
    state = false,
    flag = "collectcash",
    callback = function(v)
        if v then
            if collectThread then task.cancel(collectThread) end
            collectThread = task.spawn(function()
                while true do
                    autoCollectMyPads()
                    task.wait(2)
                end
            end)
        else
            if collectThread then
                task.cancel(collectThread)
                collectThread = nil
            end
        end
    end
})

