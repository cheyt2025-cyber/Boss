local FLYING = false
local flySpeed = 80
local connections = {}

local function getRoot(char)
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
end

local function NOFLY()
    FLYING = false
    
    -- Disconnect EVERYTHING
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    table.clear(connections)
    
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            task.wait(0.05)  -- tiny delay helps replication
            hum.PlatformStand = false  -- force twice
        end
        
        local rt = getRoot(char)
        if rt then
            -- Destroy ALL BodyMovers (more aggressive)
            for _, v in pairs(rt:GetChildren()) do
                if v:IsA("BodyMover") or v:IsA("BodyGyro") or v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("AlignPosition") then
                    pcall(function() v:Destroy() end)
                end
            end
        end
    end
    
    pcall(function()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    end)
    
    print("NOFLY executed - should be normal now")
end

local function START_FLY()
    NOFLY() -- clean slate
    
    local char = player.Character
    if not char then return end
    
    local hum = char:WaitForChild("Humanoid", 5)
    local rt = getRoot(char)
    if not hum or not rt then return end
    
    local BG = Instance.new("BodyGyro")
    BG.P = 90000
    BG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    BG.CFrame = rt.CFrame
    BG.Parent = rt
    
    local BV = Instance.new("BodyVelocity")
    BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    BV.Velocity = Vector3.new()
    BV.Parent = rt
    
    FLYING = true
    hum.PlatformStand = true
    
    table.insert(connections, RunService.RenderStepped:Connect(function()
        if not FLYING then return end
        local cam = workspace.CurrentCamera
        BG.CFrame = cam.CFrame
        
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0 then
            local worldMove = cam.CFrame:VectorToWorldSpace(moveDir)
            BV.Velocity = worldMove * flySpeed
        else
            BV.Velocity = Vector3.new()
        end
    end))
end

-- Value parsing + findTarget (unchanged from your last version)
local possibleInnerParts = {"Mesh", "Root", "Handle", "Main", "PrimaryPart", "Base", "Part"}

local function parseValue(text)
    if not text or text == "" then return 0 end
    text = text:gsub(",", ""):upper():gsub(" ", "")
    local num = tonumber(text:match("([%d%.]+)"))
    if not num then return 0 end
    if text:find("K") then return num * 1000 end
    if text:find("M") then return num * 1000000 end
    if text:find("B") then return num * 1000000000 end
    if text:find("T") then return num * 1e12 end
    return num
end

local function findTarget()
    local bestModel, bestValue, bestPrompt = nil, -1, nil
    
    for _, model in ipairs(objectsFolder:GetChildren()) do
        if not model:IsA("Model") then continue end
        
        local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
        if not prompt then continue end
        
        if autoCosmicEnabled then
            if model.Name ~= "Cosmic" then continue end
        else
            if model.Name == "Cosmic" then continue end
        end
        
        local foundValue = 0
        for _, partName in ipairs(possibleInnerParts) do
            local part = model:FindFirstChild(partName)
            if not part then continue end
            local info = part:FindFirstChild("ObjectInfo")
            if not info then continue end
            local valFolder = info:FindFirstChild("Value")
            if not valFolder then continue end
            local label = valFolder:FindFirstChild("ValueLabel")
            if not label or not label:IsA("TextLabel") then continue end
            if not label:FindFirstChild("UIStroke") then continue end
            
            foundValue = parseValue(label.Text)
            break
        end
        
        if autoCosmicEnabled then
            if foundValue > 0 then
                bestModel = model
                bestValue = foundValue
                bestPrompt = prompt
                break
            end
        else
            if foundValue > bestValue then
                bestValue = foundValue
                bestModel = model
                bestPrompt = prompt
            end
        end
    end
    return bestModel, bestValue, bestPrompt
end

