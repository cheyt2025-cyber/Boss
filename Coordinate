-- Minimize/Maximize logic
local function toggleGUI()
    guiVisible = not guiVisible
    local targetSize = guiVisible and originalSize or minimizedSize
    TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {Size = targetSize}):Play()

    -- Hide all except title, close, minimize
    for _, child in pairs(mainFrame:GetChildren()) do
        if child ~= title and child ~= closeButton and child ~= minimizeButton and child ~= mainCorner and child ~= mainStroke then
            child.Visible = guiVisible
        end
    end
end

minimizeButton.MouseButton1Click:Connect(toggleGUI)
